function shuffle(arr){
  for(let i=arr.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [arr[i],arr[j]]=[arr[j],arr[i]];
  }
  return arr;
}

function startQuiz(){
  const pool=shuffle([...VOCAB]).slice(0,25);
  quizWords=pool.map(v=>{
    const showBaku=Math.random()<0.5;
    return {display:showBaku?v.baku:v.tidak_baku, isBaku:showBaku, baku:v.baku, tidakBaku:v.tidak_baku};
  });
  curIdx=0; benar=0; salah=0; skip=0;
  goTo('page3');
  loadCard();
}

function loadCard(){
  if(curIdx>=quizWords.length){showResult();return;}
  answered=false;
  document.getElementById('card-flipper').classList.remove('flipped');
  document.getElementById('front-word').textContent=quizWords[curIdx].display;
  document.getElementById('quiz-counter').textContent=`Soal ${curIdx+1} / 25`;
  ['btn-baku','btn-tidak'].forEach(id=>{
    const b=document.getElementById(id);
    b.disabled=false; b.style.opacity='1';
  });
  startTimer();
}

function startTimer(){
  clearInterval(timerInt); timeLeft=10; updateTimer();
  timerInt=setInterval(()=>{
    timeLeft--;updateTimer();
    if(timeLeft<=0){clearInterval(timerInt);if(!answered)doSkip();}
  },1000);
}

function updateTimer(){
  const txt=document.getElementById('timer-txt');
  const fill=document.getElementById('timer-fill');
  txt.textContent=timeLeft;
  txt.classList.toggle('urgent',timeLeft<=3);
  fill.style.width=(timeLeft/10*100)+'%';
}

function doSkip(){skip++;showFlip('skip');}

function answer(type){
  if(answered)return;
  clearInterval(timerInt);answered=true;
  const w=quizWords[curIdx];
  let rt;
  if(type==='skip'){skip++;rt='skip';}
  else{
    const saysBaku=(type==='baku');
    if(saysBaku===w.isBaku){benar++;rt='benar';}
    else{salah++;rt='salah';}
  }
  showFlip(rt);
}

function showFlip(rt){
  const w=quizWords[curIdx];
  const lbl=document.getElementById('res-label');
  const ans=document.getElementById('back-ans');
  if(rt==='benar'){lbl.className='card-res-label res-benar';lbl.textContent='Benar!';}
  else if(rt==='salah'){lbl.className='card-res-label res-salah';lbl.textContent='Salah!';}
  else{lbl.className='card-res-label res-skip';lbl.textContent='Tidak dijawab';}
  ans.innerHTML=`Baku: <b>${w.baku}</b><br><span style="font-size:0.78rem;opacity:0.65">Tidak baku: ${w.tidakBaku}</span>`;
  document.getElementById('card-flipper').classList.add('flipped');
  ['btn-baku','btn-tidak'].forEach(id=>{
    const b=document.getElementById(id);b.disabled=true;b.style.opacity='0.45';
  });
  setTimeout(()=>{curIdx++;loadCard();},2200);
}

function showResult(){
  const score = benar*4;
  addToTotalScore(score);
  loadTotalScore();
  const stamp=document.getElementById('stamp-overlay');
  stamp.style.animation='none';
  void stamp.offsetHeight;
  stamp.style.animation='';
  document.getElementById('stamp-name').textContent='Name: '+userName;
  document.getElementById('stamp-xname').textContent='Username X: '+(userXname || '—');
  document.getElementById('stamp-gender').textContent='Gender: '+userGender.charAt(0).toUpperCase()+userGender.slice(1);
  goTo('page4');
}

function retryQuiz(){startQuiz();}

function saveResult(){
  const el = document.querySelector('.result-wrap');
  if(!el){ alert('Belum ada hasil!'); return; }
  // Use html2canvas-like approach: create a canvas
  import_html2canvas();
}

function import_html2canvas(){
  const s=document.createElement('script');
  s.src='https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
  s.onload=function(){
    const el=document.querySelector('.result-wrap');
    html2canvas(el,{backgroundColor:'#fdf6f8',scale:2,useCORS:true}).then(canvas=>{
      const a=document.createElement('a');
      a.download='hasil-quiz-kosakata.png';
      a.href=canvas.toDataURL('image/png');
      a.click();
    });
  };
  document.head.appendChild(s);
}

</script>
