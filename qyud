<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kosakata Baku/Tidak Baku</title>
<style>
@font-face {
  font-family: 'StarryType';
  src: url('data:font/truetype;base64,') format('truetype');
}
@font-face {
  font-family: 'RabbitsApril';
  src: url('data:font/truetype;base64,') format('truetype');
}
@font-face {
  font-family: 'OldNewspaper';
  src: url('data:font/truetype;base64,') format('truetype');
}
@font-face {
  font-family: 'KGMelonheadz';
  src: url('data:font/truetype;base64,') format('truetype');
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: Georgia, serif; min-height:100vh; overflow-x:hidden; }
.page { display:none; min-height:100vh; width:100%; position:relative; }
.page.active { display:flex; flex-direction:column; align-items:center; justify-content:center; }

/* PAGE 1 WOIIIIIIIIIIIIIIIIIIIIIIIIIIII */
#page1 {
  background: linear-gradient(145deg, #fdf6f8 0%, #f5e0e8 25%, #eacfd9 55%, #e0b8c8 80%, #ce9fae 100%);
  overflow:hidden;
}
#page1::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(ellipse at 25% 15%, rgba(255,255,255,0.5) 0%, transparent 55%),
              radial-gradient(ellipse at 75% 85%, rgba(206,143,158,0.25) 0%, transparent 45%);
  pointer-events:none;
}
.tape {
  position:absolute; height:24px;
  background: rgba(234,207,217,0.52);
  border-radius:2px; z-index:10;
  border:1px solid rgba(255,255,255,0.5);
}
.tape-tl { width:85px; top:-8px; left:50%; transform:translateX(-50%) rotate(-5deg); }
.tape-tr { width:60px; top:10px; right:-6px; transform:rotate(12deg); }
.tape-bl { width:70px; bottom:10px; left:-4px; transform:rotate(-9deg); }

.paper-card {
  background: rgba(255,252,250,0.9);
  border-radius:3px; padding:44px 50px 38px;
  text-align:center; position:relative;
  box-shadow: 3px 5px 22px rgba(180,120,140,0.2), 0 1px 6px rgba(0,0,0,0.06);
  max-width:390px; width:88%;
  animation: fadeInUp 0.9s ease forwards;
}
@keyframes fadeInUp {
  from { opacity:0; transform:translateY(28px); }
  to { opacity:1; transform:translateY(0); }
}
.paper-title { font-family:'StarryType',cursive; font-size:2.3rem; color:#5a3344; line-height:1.25; margin-bottom:12px; }
.paper-sub { font-family:'RabbitsApril',cursive; font-size:0.88rem; color:#9a6878; margin-bottom:28px; }
.btn-start {
  background:linear-gradient(135deg,#CE8F9E,#b87888); color:white; border:none;
  padding:12px 28px; border-radius:28px; font-size:0.86rem; cursor:pointer;
  font-family:Georgia,serif; box-shadow:0 4px 14px rgba(206,143,158,0.38);
  transition:transform 0.2s, box-shadow 0.2s; letter-spacing:0.3px;
}
.btn-start:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(206,143,158,0.5); }

/* WNIH PAGE 2 */
#page2 {
  background: linear-gradient(145deg, #fdf6f8 0%, #f5e0e8 25%, #eacfd9 55%, #e0b8c8 80%, #ce9fae 100%);
  padding:30px 20px;
}
.id-card-wrap { animation:fadeInUp 0.7s ease forwards; width:100%; max-width:500px; }
.id-card {
  border-radius:14px; padding:20px; position:relative;
  display:grid; grid-template-columns:115px 1fr; gap:16px;
  box-shadow:5px 8px 26px rgba(0,0,0,0.13);
  border:2.5px solid #CE8F9E;
  background:linear-gradient(135deg,#fef2f4,#fde8ed);
  transition:background 0.5s, border-color 0.5s; min-height:200px;
}
.id-star-row {
  position:absolute; top:6px; left:0; right:0;
  display:flex; justify-content:space-around; padding:0 10px;
  font-size:9px; opacity:0.3;
}
.id-photo-box {
  width:110px; height:135px; border:2px solid #CE8F9E;
  border-radius:5px; overflow:hidden; background:#f0e0e6;
  margin-top:20px; flex-shrink:0;
  transition:border-color 0.4s;
}
.id-photo-box img { width:100%; height:100%; object-fit:cover; }
.id-right { display:flex; flex-direction:column; gap:9px; margin-top:20px; }
.id-title {
  font-family:'OldNewspaper',serif; font-size:0.9rem;
  letter-spacing:1.5px; text-transform:uppercase;
  border-bottom:1.5px solid #CE8F9E; padding-bottom:5px;
  color:#5a3344; transition:border-color 0.4s,color 0.4s;
}
.id-field { display:flex; flex-direction:column; gap:2px; }
.id-field label { font-family:'OldNewspaper',serif; font-size:0.58rem; letter-spacing:1.5px; text-transform:uppercase; color:#9a6878; }
.id-input {
  background:transparent; border:none; border-bottom:1px dashed #CE8F9E;
  font-family:'OldNewspaper',serif; font-size:0.82rem; color:#5a3344;
  width:100%; outline:none; padding:2px 0; transition:border-color 0.4s;
}
.id-input::placeholder { opacity:0.35; font-style:italic; }
.gender-row { display:flex; gap:5px; margin-top:2px; }
.gender-btn {
  flex:1; padding:5px 0; border-radius:18px;
  border:1.5px solid #CE8F9E; background:transparent;
  font-family:'OldNewspaper',serif; font-size:0.7rem;
  cursor:pointer; color:#5a3344; transition:all 0.22s;
}
.gender-btn:hover { background:rgba(206,143,158,0.15); }
.gender-btn.active { color:white; background:#CE8F9E; border-color:#CE8F9E; }
.btn-enter {
  margin-top:12px; width:100%; padding:10px; border-radius:28px; border:none;
  background:linear-gradient(135deg,#CE8F9E,#b87888); color:white;
  font-family:Georgia,serif; font-size:0.86rem; cursor:pointer;
  box-shadow:0 4px 14px rgba(206,143,158,0.38); transition:transform 0.2s;
}
.btn-enter:hover { transform:translateY(-2px); }

/* GENDER THEMES */
.id-card.boy { background:linear-gradient(135deg,#F0ECDD,#dce6f2); border-color:#8BA3C5; }
.id-card.boy .id-title { border-color:#495B7D; color:#23354D; }
.id-card.boy .id-photo-box { border-color:#8BA3C5; }
.id-card.boy .id-input { border-color:#8BA3C5; color:#23354D; }
.id-card.boy .id-field label { color:#6a7a9a; }
.id-card.boy .gender-btn { border-color:#8BA3C5; color:#23354D; }
.id-card.boy .gender-btn.active { background:#495B7D; border-color:#495B7D; color:white; }
.id-card.boy .btn-enter { background:linear-gradient(135deg,#8BA3C5,#495B7D); box-shadow:0 4px 14px rgba(73,91,125,0.38); }

.id-card.girl { background:linear-gradient(135deg,#fef0f4,#fde4ec); border-color:#D86487; }
.id-card.girl .id-title { border-color:#D86487; color:#4A202A; }
.id-card.girl .id-photo-box { border-color:#D86487; }
.id-card.girl .id-input { border-color:#EEAAC3; color:#4A202A; }
.id-card.girl .id-field label { color:#a06070; }
.id-card.girl .gender-btn { border-color:#D86487; color:#4A202A; }
.id-card.girl .gender-btn.active { background:#D86487; border-color:#D86487; color:white; }
.id-card.girl .btn-enter { background:linear-gradient(135deg,#EEAAC3,#D86487); box-shadow:0 4px 14px rgba(216,100,135,0.38); }

.id-card.meong { background:linear-gradient(135deg,#f8f0ea,#ede0d5); border-color:#8A6C5F; }
.id-card.meong .id-title { border-color:#8A6C5F; color:#544339; }
.id-card.meong .id-photo-box { border-color:#8A6C5F; }
.id-card.meong .id-input { border-color:#BFA38A; color:#544339; }
.id-card.meong .id-field label { color:#7a6055; }
.id-card.meong .gender-btn { border-color:#8A6C5F; color:#544339; }
.id-card.meong .gender-btn.active { background:#544339; border-color:#544339; color:white; }
.id-card.meong .btn-enter { background:linear-gradient(135deg,#BFA38A,#544339); box-shadow:0 4px 14px rgba(84,67,57,0.38); }

/* ID MINI */
#id-mini {
  position:fixed; top:12px; left:12px; z-index:200;
  background: linear-gradient(135deg,#fef2f4,#fde8ed);
  border-radius:8px; padding:6px 10px 6px 7px;
  display:flex; align-items:center; gap:8px;
  box-shadow:0 2px 12px rgba(0,0,0,0.12); border:1.5px solid #CE8F9E;
  opacity:0; pointer-events:none;
  transition:opacity 0.4s, background 0.5s, border-color 0.5s;
}
#id-mini.show { opacity:1; pointer-events:auto; }
#id-mini img { width:28px; height:36px; object-fit:cover; border-radius:3px; border:1px solid #CE8F9E; transition:border-color 0.5s; }
.mini-info { display:flex; flex-direction:column; gap:1px; }
.mini-title { font-family:'OldNewspaper',serif; font-size:0.55rem; color:#9a6878; letter-spacing:1px; text-transform:uppercase; border-bottom:1px solid #eacfd9; padding-bottom:2px; margin-bottom:1px; transition:color 0.5s, border-color 0.5s; }
.mini-name { font-family:'OldNewspaper',serif; font-size:0.68rem; color:#5a3344; font-weight:bold; transition:color 0.5s; }
.mini-gender { font-family:'RabbitsApril',cursive; font-size:0.58rem; color:#9a6878; transition:color 0.5s; }

/* PAGE 3 */
#page3 {
  background: linear-gradient(145deg, #fdf6f8 0%, #f5e0e8 25%, #eacfd9 55%, #e0b8c8 80%, #ce9fae 100%);
  padding:70px 20px 36px; justify-content:flex-start;
}
.quiz-wrap { width:100%; max-width:420px; margin:0 auto; display:flex; flex-direction:column; align-items:center; gap:16px; }
.quiz-info-row { width:100%; display:flex; justify-content:space-between; align-items:center; }
.quiz-counter { font-family:'RabbitsApril',cursive; font-size:0.82rem; color:#5a3344; }
.timer-txt { font-family:'OldNewspaper',serif; font-size:1.15rem; color:#CE8F9E; font-weight:bold; transition:color 0.3s; }
.timer-txt.urgent { color:#c0392b; }
.timer-track { width:100%; height:5px; background:rgba(255,255,255,0.45); border-radius:4px; overflow:hidden; }
.timer-fill { height:100%; background:linear-gradient(90deg,#CE8F9E,#818455); border-radius:4px; transition:width 1s linear; }

/* FLASH CARD */
.card-scene { width:340px; height:200px; perspective:1000px; }
.card-flipper {
  width:100%; height:100%; position:relative;
  transform-style:preserve-3d; transition:transform 0.65s ease;
}
.card-flipper.flipped { transform:rotateY(180deg); }
.card-face {
  position:absolute; inset:0; backface-visibility:hidden;
  border-radius:10px; display:flex; align-items:center; justify-content:center;
  background:#fef8f9; box-shadow:0 4px 18px rgba(180,120,140,0.22);
  overflow:hidden;
}
.card-back { transform:rotateY(180deg); }
.lace-border-svg { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; }
.card-content { position:relative; z-index:2; text-align:center; padding:18px; }
.card-word { font-family:'KGMelonheadz',cursive; font-size:2rem; color:#5a3344; line-height:1.1; }
.card-hint { font-family:'RabbitsApril',cursive; font-size:0.68rem; color:#bfa0a8; margin-top:5px; }
.card-res-label {
  font-family:'RabbitsApril',cursive; font-size:0.78rem;
  padding:3px 14px; border-radius:18px; margin-bottom:7px; display:inline-block;
}
.res-benar { background:#d6f0e0; color:#2d6a4f; }
.res-salah { background:#fde2e2; color:#c0392b; }
.res-skip { background:#f0ecd4; color:#5a4a20; }
.card-ans { font-family:'KGMelonheadz',cursive; font-size:1rem; color:#5a3344; line-height:1.5; }

.quiz-btns { display:flex; gap:9px; }
.q-btn {
  padding:9px 18px; border-radius:22px; border:2px solid #CE8F9E;
  background:rgba(255,255,255,0.72); font-family:Georgia,serif;
  font-size:0.8rem; cursor:pointer; color:#5a3344; transition:all 0.2s;
}
.q-btn:hover { background:#CE8F9E; color:white; }
.q-btn.skip { border-color:#818455; color:#5a5030; }
.q-btn.skip:hover { background:#818455; color:white; }
.q-btn:disabled { opacity:0.45; cursor:default; pointer-events:none; }

/* PAGE 4 */
#page4 {
  background: linear-gradient(145deg, #fdf6f8 0%, #f5e0e8 25%, #eacfd9 55%, #e0b8c8 80%, #ce9fae 100%);
  padding:30px 20px; overflow:hidden; position:relative;
}
.result-wrap { display:flex; flex-direction:column; align-items:center; }
.machine-anim { opacity:0; animation:machIn 0.8s ease 0.4s forwards; display:flex; flex-direction:column; align-items:center; }
@keyframes machIn { from{opacity:0;transform:translateY(30px);} to{opacity:1;transform:translateY(0);} }
.machine-body {
  width:180px; height:50px;
  background:linear-gradient(180deg,#d6d6d6,#aaa);
  border-radius:10px 10px 0 0;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 14px rgba(0,0,0,0.18); position:relative; z-index:3;
}
.machine-slot { width:120px; height:9px; background:#333; border-radius:2px; }
.receipt-wrap {
  width:180px; max-height:0; overflow:hidden;
  background:#fff; position:relative; z-index:2;
  animation:recOut 1.2s ease 2.2s forwards;
  box-shadow:2px 4px 14px rgba(0,0,0,0.1);
}
@keyframes recOut { from{max-height:0;} to{max-height:700px;} }
.receipt-inner { padding:16px 14px 22px; opacity:1; }
@keyframes fadeR { to{opacity:1;} }
.r-title { font-family:'OldNewspaper',serif; font-size:0.92rem; text-align:center; letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; color:#222; }
.r-line { border:none; border-top:1px dashed #ccc; margin:6px 0; }
.r-row { display:flex; justify-content:space-between; font-family:'OldNewspaper',serif; font-size:0.66rem; color:#333; margin:3px 0; }
.r-row.bold { font-size:0.74rem; font-weight:bold; border-top:1px solid #bbb; padding-top:5px; margin-top:5px; }
.r-lotus { text-align:center; font-size:1.5rem; margin:10px 0 3px; }
.r-credit { text-align:center; font-family:'OldNewspaper',serif; font-size:0.52rem; color:#999; letter-spacing:1px; }
.zigzag {
  width:180px; height:10px;
  background: linear-gradient(135deg,#fff 33.33%,transparent 33.33%) 0 0,
              linear-gradient(225deg,#fff 33.33%,transparent 33.33%) 0 0;
  background-size:10px 10px; background-color:#ddd;
}

/* STAMP */
.stamp-overlay {
  transform: scale(0);
  z-index:10; opacity:0;
  animation:stampPop 0.6s cubic-bezier(0.175,0.885,0.32,1.275) 4.6s forwards;
  margin-top: 10px;
}
@keyframes stampPop {
  0% { transform:scale(3); opacity:0; }
  55% { transform:scale(0.88); opacity:1; }
  100% { transform:scale(1); opacity:1; }
}
.stamp-card {
  background: linear-gradient(135deg,#fef2f4,#fde8ed);
  border-radius:10px; padding:8px 12px;
  border:2.5px solid #CE8F9E; box-shadow:0 4px 20px rgba(0,0,0,0.22);
  display:flex; align-items:center; gap:8px;
  font-family:'OldNewspaper',serif; font-size:0.64rem; color:#5a3344; min-width:155px;
  transition:border-color 0.4s, background 0.5s, color 0.5s;
}
.stamp-card img { width:36px; height:44px; object-fit:cover; border-radius:3px; border:1.5px solid #CE8F9E; transition:border-color 0.5s; }
.stamp-info { display:flex; flex-direction:column; gap:3px; }
.stamp-name { font-size:0.7rem; font-weight:bold; }
.stamp-gender { font-size:0.56rem; opacity:0.65; }
#page4 #id-mini { display: none !important; }
.btn-retry {
  margin-top:18px; padding:10px 26px; border-radius:28px; border:none;
  background:linear-gradient(135deg,#CE8F9E,#b87888); color:white;
  font-family:Georgia,serif; font-size:0.85rem; cursor:pointer;
  box-shadow:0 4px 14px rgba(206,143,158,0.38); opacity:0;
  animation:fadeR 0.5s ease 5.3s forwards; transition:transform 0.2s;
}
.btn-retry:hover { transform:translateY(-2px); }

.btn-back {
  position: fixed; top: 12px; right: 12px; z-index: 200;
  background: rgba(255,255,255,0.85); border: 1.5px solid #CE8F9E;
  border-radius: 20px; padding: 5px 14px;
  font-family: Georgia, serif; font-size: 0.75rem; color: #5a3344;
  cursor: pointer; box-shadow: 0 2px 8px rgba(206,143,158,0.2);
  transition: background 0.2s;
  display: none;
}
.btn-back:hover { background: #CE8F9E; color: white; }
.btn-back.show { display: block; }


.score-card-wrap {
  position: relative; margin-bottom: 14px;
  animation: fadeInUp 0.7s ease forwards;
}
.score-card {
  background: rgba(255,252,250,0.88); border-radius: 3px;
  padding: 10px 22px; text-align: center; position: relative;
  box-shadow: 2px 3px 12px rgba(180,120,140,0.15);
  font-family: 'OldNewspaper', serif;
  display: flex; align-items: center; gap: 12px; justify-content: center;
}
.score-tape {
  position: absolute; width: 60px; height: 20px;
  background: rgba(234,207,217,0.5); border-radius: 2px;
  top: -8px; left: 50%; transform: translateX(-50%) rotate(-3deg);
  border: 1px solid rgba(255,255,255,0.5);
}
.score-text { font-size: 0.8rem; color: #5a3344; }
.score-num { font-size: 1rem; color: #CE8F9E; font-weight: bold; }
.btn-reset-score {
  font-size: 0.65rem; color: #9a6878; background: none; border: none;
  cursor: pointer; text-decoration: underline; font-family: Georgia, serif;
  padding: 0; margin-left: 4px;
}
.btn-reset-score:hover { color: #CE8F9E; }


.btn-save {
  margin-top: 12px; padding: 10px 26px; border-radius: 28px; border: none;
  background: linear-gradient(135deg, #818455, #6a6e44);
  color: white; font-family: 'KGMelonheadz', cursive;
  font-size: 0.88rem; cursor: pointer;
  box-shadow: 0 4px 14px rgba(129,132,85,0.38); opacity: 0;
  animation: fadeR 0.5s ease 5.8s forwards; transition: transform 0.2s;
}
.btn-save:hover { transform: translateY(-2px); }


#page1,#page2,#page3,#page4{
  background-size: 400% 400% !important;
  animation: bgMove 12s ease infinite !important;
}
@keyframes bgMove{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}

/* PAGE 3 png frame flip card */
#page3 .card-scene{
  width: min(420px, 94vw) !important;
  aspect-ratio: 1400 / 1140 !important;
  height: auto !important;
  perspective: 1000px;
}
#page3 .card-flipper{
  width: 100% !important;
  height: 100% !important;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.65s ease;
}
#page3 .card-face{
  background: transparent !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  overflow: hidden;
}
#page3 .card-face::before,
#page3 .card-face::after{
  display:none !important;
}
#page3 .flash-frame{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit: fill;
  pointer-events:none;
  user-select:none;
}
#page3 .lace-border-svg{ display:none !important; }
#page3 .card-content{
  position:absolute;
  inset: 14% 14% 13% 14%;
  z-index:2;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
}
#page3 .card-word{ font-size: 1.72rem; line-height: 1.05; }
#page3 .card-hint{ font-size: 0.74rem; margin-top: 6px; }
#page3 .card-res-label{ font-size: 0.82rem; }
#page3 .card-ans{ font-size: 0.97rem; }

/* PAGE 4 keep only lower card */
#page4 .machine-anim{
  opacity: 1 !important;
  animation: none !important;
  display:flex;
  flex-direction:column;
  align-items:center;
}
#page4 .machine-body,
#page4 .receipt-wrap,
#page4 .zigzag{
  display:none !important;
}
#page4 .stamp-overlay{
  margin-top: 52px;
}
#page4 .stamp-card{
  min-width: 175px;
}
#page4 .stamp-xname{
  font-size: 0.56rem;
  opacity: 0.75;
}
#page4 .btn-retry{
  margin-top: 18px;
}
#page4 #id-mini{ display:none !important; }

</style>
</head>
<body>

<!-- ID MINI -->
<div id="id-mini">
  <img id="mini-photo" src="" alt="">
  <div class="mini-info">
    <span class="mini-title">Main Character ID</span>
    <span class="mini-name" id="mini-name-txt"></span>
    <span class="mini-gender" id="mini-gender-txt"></span>
  </div>
</div>

<button class="btn-back" id="btn-back" onclick="goBack()">← Kembali</button>

<!-- PAGE 1 -->
<div id="page1" class="page active">
  <div class="score-card-wrap">
  <div class="score-card">
    <div class="score-tape"></div>
    <span class="score-text">Skor Tertinggi Kamu:</span>
    <span class="score-num" id="display-total-score">0</span>
    <button class="btn-reset-score" onclick="resetScore()">reset skor</button>
  </div>
</div>
<div class="paper-card">
    <div class="tape tape-tl"></div>
    <div class="tape tape-tr"></div>
    <div class="tape tape-bl"></div>
    <div class="paper-title">Kosakata Baku/<br>Tidak Baku</div>
    <div class="paper-sub">dibuat sepenuh hati oleh @desclaid on X</div>
    <button class="btn-start" onclick="goTo('page2')">aku bersedia untuk mengasah memori!</button>
  </div>
</div>

<!-- PAGE 2 -->
<div id="page2" class="page">
