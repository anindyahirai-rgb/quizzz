let userName='', userGender='', userPhoto=PP_GREY, userXname='';
let pageHistory = ['page1'];

function goTo(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
  if(id !== 'page1') {
    document.getElementById('btn-back').classList.add('show');
  } else {
    document.getElementById('btn-back').classList.remove('show');
  }
  pageHistory.push(id);
}

function goBack(){
  pageHistory.pop();
  const prev = pageHistory[pageHistory.length-1] || 'page1';
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(prev).classList.add('active');
  window.scrollTo(0,0);
  if(prev === 'page1'){
    document.getElementById('btn-back').classList.remove('show');
    loadTotalScore();
  }
}

function loadTotalScore(){
  const s = parseInt(localStorage.getItem('quizTotalScore')||'0');
  document.getElementById('display-total-score').textContent = s;
}

function resetScore(){
  if(confirm('Reset skor jadi 0?')){
    localStorage.setItem('quizTotalScore','0');
    loadTotalScore();
  }
}

function addToTotalScore(s){
  const cur = parseInt(localStorage.getItem('quizTotalScore')||'0');
  localStorage.setItem('quizTotalScore', cur+s);
}

